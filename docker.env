# --- container-internal hostnames and ports ---

# TCP logging server (to enable unified management of logs in a multiprocessing context).
# Not exposed externally (although can be if needed), logs to stderr (captured by Docker).
LOGGING_SERVER_HOST=0.0.0.0
LOGGING_SERVER_PORT=9020
# API server for the pipeline
# (used by the dashboard, also exposed externally for API access)
PIPELINE_SERVER_HOST=0.0.0.0
PIPELINE_SERVER_PORT=8081
# dashboard
# (exposed externally for accessing the dashboard's web interface)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8091

# --- runtime params ---

# The start method to use for child processes.
# IMPORTANT: Do not use `fork` for the current implementation
# (conflicted with shutdown behaviour of the pipeline worker process due to,
# it inheriting uvicorn's SIGTERM handler [it having been created
# inside a uvicorn context]).
# Use `forkserver` or `spawn` instead.
MULTIPROCESSING_START_METHOD=forkserver

# The number of threads to which to offload
# the rendering of the main HTML element of the Gradio dashboard
MAIN_DASHBOARD_RENDERING_MAX_THREADS=1

# The logging level for the pipeline server and the dashboard.
# All log records are forwarded to the internal TCP logging server
# which is set to output everything into stderr.
LOGGING_LEVEL=debug

# --- assets ---

# The directory in the container's filesystem
# from which configs and the video file are read.
# Notes:
# - In a local non-containerised dev environment,
# this should just be set to a local assets directory.
# - In a Docker container, this is the mount point
# into which an external directory is being mounted.
ASSETS_DIR=/app/assets

# configs

# NOTE: These paths, and any paths inside these configs,
# are resolved relative to ASSETS_DIR.
# This means:
# - for Docker deployment: define relative to the source of the bind mount;
# - for local dev use: define relative to ASSETS_DIR.
PIPELINE_CONFIG=config/pipeline/pipeline.yaml
DASHBOARD_CONFIG=config/dashboard/dashboard.yaml
LIVE_STATE_RENDERER_CONFIG=config/dashboard/live_state_renderer.yaml